# backend/.env.example

# Provider: "openai" or "gemini"
# LLM_PROVIDER=openai
LLM_PROVIDER=gemini

# Preferred canonical API key (if set, used by whichever provider)
LLM_API_KEY=

# OpenAI-specific (optional if LLM_API_KEY set)
# OPENAI_API_KEY=

# Gemini-specific (optional if LLM_API_KEY set)
GEMINI_API_KEY=

# Model to use (change as desired)
# LLM_MODEL=gpt-4o-mini
LLM_MODEL=gemini-2.5-flash
MAX_TOKENS=4096

# App settings
HOST=127.0.0.1
PORT=8000
FRONTEND_URL=http://localhost:5173
